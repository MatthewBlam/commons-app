# Copy to .env and fill in. Values are inlined into the main bundle at build
# time by the `define` block in electron.vite.config.ts — so everything here is
# readable by anyone who has the app. Nothing confidential may live in this file.

# Notion OAuth. Create an integration at https://www.notion.so/my-integrations
# and register http://localhost:21337/callback as its redirect URI.
NOTION_CLIENT_ID=

# The Cloudflare Worker that performs the Notion token exchange. Notion's token
# endpoint requires the client *secret* and has no public-client mode, so that
# secret cannot ship in the app — it lives in the Worker instead. Deploy from
# worker/ (see worker/README.md) and paste the full endpoint URL here, e.g.
# https://commons-notion-auth.<subdomain>.workers.dev/notion/token
NOTION_TOKEN_PROXY_URL=

# Google OAuth. The client MUST be registered as a "Desktop app" client. Google
# designates a Desktop client's secret non-confidential — PKCE is what secures
# the flow — which is the only reason it is safe to inline below. Re-register it
# as a "Web" client and this line becomes a real credential leak.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostHog project key. Write-only and safe to ship in the bundle.
POSTHOG_API_KEY=
