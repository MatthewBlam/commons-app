{
  "name": "commons-app",
  "version": "0.1.0",
  "description": "Search your club's docs — local-first RAG for student organizations",
  "type": "module",
  "main": "./dist/main/index.js",
  "author": "Matthew Blam",
  "license": "MIT",
  "homepage": "https://github.com/MatthewBlam/commons-app#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MatthewBlam/commons-app.git"
  },
  "bugs": {
    "url": "https://github.com/MatthewBlam/commons-app/issues"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "start": "electron-vite preview",
    "postinstall": "rimraf node_modules/better-sqlite3/build && electron-rebuild -w better-sqlite3",
    "dev": "electron-vite dev",
    "build": "pnpm run typecheck && pnpm run lint && pnpm run test && electron-vite build",
    "package": "pnpm run build && electron-forge package",
    "make": "pnpm run build && electron-forge make",
    "make:mac": "pnpm run build && electron-forge make --platform darwin",
    "make:win": "pnpm run build && electron-forge make --platform win32",
    "test": "pnpm rebuild better-sqlite3 && vitest run",
    "posttest": "rimraf node_modules/better-sqlite3/build node_modules/.vite && electron-rebuild -w better-sqlite3",
    "test:watch": "pnpm rebuild better-sqlite3 && vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@googleapis/drive": "^20.2.0",
    "@notionhq/client": "^5.22.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^1.21.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "posthog-node": "^5.41.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "dotenv": "^17.4.2",
    "electron": "^39.2.6",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^29.1.1",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.9"
  }
}
